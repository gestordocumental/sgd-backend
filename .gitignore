# ── Node.js ───────────────────────────────────────────────────────────────────
**/node_modules/
**/dist/
**/build/
**/.npm
**/.npm-cache/
**/*.tsbuildinfo
**/.pnp
**/.pnp.js

# ── Variables de entorno (NUNCA subir al repo) ────────────────────────────────
**/.env
**/.env.local
**/.env.*.local
**/.env.development
**/.env.test
**/.env.production
# Permitir el ejemplo de referencia
!**/.env.example

# ── Credenciales y secretos ───────────────────────────────────────────────────
**/*.pem
**/*.key
**/*.cert
**/*.p12
**/*.pfx
**/.npmrc
**/.yarnrc

# ── Logs ──────────────────────────────────────────────────────────────────────
**/logs/
**/*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# ── IDEs ──────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ── Sistema operativo ─────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
Thumbs.db
desktop.ini
ehthumbs.db

# ── Docker ────────────────────────────────────────────────────────────────────
# Ignorar overrides locales pero conservar docker-compose.yml base
docker-compose.override.yml

# ── Kubernetes — secrets con valores reales ───────────────────────────────────
# Los archivos *secret.yaml del repo son plantillas con valores de desarrollo.
# En producción los secrets se gestionan con Vault o Sealed Secrets.
# Si generas overrides locales con valores reales, nómbralos *.secret.local.yaml
**/*.secret.local.yaml

# ── Helm ──────────────────────────────────────────────────────────────────────
**/charts/*.tgz

# ── Cobertura de tests ────────────────────────────────────────────────────────
**/coverage/
**/.nyc_output/
**/test-results/

# ── Archivos temporales ───────────────────────────────────────────────────────
**/tmp/
**/temp/
**/*.local
**/*.tmp
**/*.bak
*.pdf
