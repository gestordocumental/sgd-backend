NODE_ENV=development
PORT=3001

# PostgreSQL
DB_HOST=localhost
# Railway Starter ~25 conns → budget 80% = 20 → 20 / 5 PG services ≈ 4 each.
# Para Developer (50) usar 8; para Pro (100+) usar 15. Nunca superar floor(max_connections*0.8/services).
DB_POOL_SIZE=5
DB_PORT=5432
DB_NAME=user_db
DB_USERNAME=postgres
DB_PASSWORD=

# Redis — tokens de invitación (TTL corto) y revocación de super-admin
REDIS_HOST=localhost
REDIS_PORT=6379
# Requerido. Local: redis_local_pass. Producción: openssl rand -hex 32 (nunca vacío).
REDIS_PASSWORD=

# JWT — misma clave que auth-service (solo para verificar firma)
JWT_SECRET=
JWT_SECRET_KID=v1
JWT_SECRET_PREV=
JWT_SECRET_PREV_KID=

# Super admin — se crea automáticamente en cada arranque en frío si no existe.
# Requerido: el servicio lanza error al iniciar si está vacío.
SUPER_ADMIN_EMAIL=admin@sgd.local

# ── Tokens internos de servicio a servicio ────────────────────────────────────
# Cada token identifica un par (origen → destino). Generar con:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# user-service envía a auth-service:
INTERNAL_TOKEN_USER_AUTH=
# user-service envía a org-service (para validar departamentoId/areaId/cargoId en PATCH /users/:id):
INTERNAL_TOKEN_USER_ORG=
# Tokens aceptados en endpoints /internal/* de user-service (uno por llamante):
INTERNAL_TOKEN_AUTH_USER=
INTERNAL_TOKEN_NOTIF_USER=
INTERNAL_TOKEN_WORKFLOW_USER=
INTERNAL_TOKEN_ORG_USER=

# ── IP allowlisting — defensa en profundidad para endpoints /internal/* ───────
# CIDR(s) permitidos como origen de llamadas internas (separados por coma).
# Railway private network: 100.64.0.0/10
# Local dev / tests:       127.0.0.1,::1
# Dejar vacío para deshabilitar la comprobación (solo token).
INTERNAL_ALLOWED_CIDRS=

# URL interna del auth-service
# Local (directo):   http://localhost:3000
# Local (KinD):      http://auth-service.gestor-documental.svc.cluster.local
# Railway:           http://auth-service.railway.internal:3000
AUTH_SERVICE_URL=http://localhost:3000

# URL interna del org-service (para validar referencias de estructura organizacional)
ORG_SERVICE_URL=http://localhost:3002

# ─── Object Storage ───────────────────────────────────────────────────────────
# Bucket público — las URLs se sirven directamente al browser sin firma.
# Local (MinIO docker-compose):
#   STORAGE_ENDPOINT=http://localhost:9000
#   STORAGE_FORCE_PATH=true
#   STORAGE_PUBLIC_URL=http://localhost:9000/avatares
# Railway (R2 — mismo account que document-service, bucket separado con acceso público):
#   STORAGE_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
#   STORAGE_FORCE_PATH=false
#   STORAGE_PUBLIC_URL=https://pub-<hash>.r2.dev  (o dominio custom del bucket)
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_REGION=auto
STORAGE_ACCESS_KEY=minio_admin
STORAGE_SECRET_KEY=minio_secret_local
STORAGE_BUCKET=avatares
STORAGE_FORCE_PATH=true
STORAGE_PUBLIC_URL=http://localhost:9000/avatares

# Kafka (producer — eventos de usuario: USER_CREATED, USER_DELETED, USER_SUPER_ADMIN_REVOKED, etc.)
KAFKA_BROKER=localhost:9094
KAFKA_CLIENT_ID=user-service

# OpenTelemetry — distributed tracing
# Dejar vacío para deshabilitar (ej: en tests). Jaeger local: docker compose up jaeger
OTEL_EXPORTER_OTLP_ENDPOINT=

# Sentry error tracking (leave empty to disable)
SENTRY_DSN=
