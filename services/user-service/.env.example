NODE_ENV=development
PORT=3001

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_POOL_SIZE=15
DB_NAME=user_db
DB_USERNAME=postgres
DB_PASSWORD=

# â”€â”€ Tokens internos de servicio a servicio â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
# Cada token identifica un par (origen â†’ destino).  Generar con:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# user-service envÃ­a a auth-service:
INTERNAL_TOKEN_USER_AUTH=
# user-service envÃ­a a org-service (para validar departamentoId/areaId/cargoId en PATCH /users/:id):
INTERNAL_TOKEN_USER_ORG=
# Tokens aceptados en endpoints /internal/* de user-service (uno por llamante):
INTERNAL_TOKEN_AUTH_USER=
INTERNAL_TOKEN_NOTIF_USER=
INTERNAL_TOKEN_WORKFLOW_USER=
INTERNAL_TOKEN_ORG_USER=

# URL interna del auth-service
# Local (directo):   http://localhost:3000
# Local (KinD):      http://auth-service.gestor-documental.svc.cluster.local
# Railway:           http://auth-service.railway.internal:3000
AUTH_SERVICE_URL=http://localhost:3000

# URL interna del org-service (para validar referencias de estructura organizacional)
ORG_SERVICE_URL=http://localhost:3002

HEALTH_PATH=/health

# Redis — tokens de invitación (TTL corto)
REDIS_HOST=localhost
REDIS_PORT=6379
# Requerido. Local: redis_local_pass. Producción: openssl rand -hex 32 (nunca vacío).
REDIS_PASSWORD=

# JWT â€” misma clave que auth-service (solo para verificar firma)
JWT_SECRET=
JWT_SECRET_KID=v1
JWT_SECRET_PREV=
JWT_SECRET_PREV_KID=

# â”€â”€â”€ Object Storage (avatares) â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
# Bucket pÃºblico â€” las URLs se sirven directamente al browser sin firma.
# Local (MinIO docker-compose):
#   STORAGE_ENDPOINT=http://localhost:9000
#   STORAGE_FORCE_PATH=true
#   STORAGE_PUBLIC_URL=http://localhost:9000/avatares
# Railway (R2 â€” mismo account que document-service, bucket separado con acceso pÃºblico):
#   STORAGE_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
#   STORAGE_FORCE_PATH=false
#   STORAGE_PUBLIC_URL=https://pub-<hash>.r2.dev  (o dominio custom del bucket)
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_REGION=auto
STORAGE_ACCESS_KEY=minio_admin
STORAGE_SECRET_KEY=minio_secret_local
STORAGE_BUCKET=avatares
STORAGE_FORCE_PATH=true
STORAGE_PUBLIC_URL=http://localhost:9000/avatares

# Sentry error tracking (leave empty to disable)
SENTRY_DSN=
