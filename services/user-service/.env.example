NODE_ENV=development
PORT=3001

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=user_db
DB_USERNAME=postgres
DB_PASSWORD=

# ── Tokens internos de servicio a servicio ────────────────────────────────────
# Cada token identifica un par (origen → destino).  Generar con:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# user-service envía a auth-service:
INTERNAL_TOKEN_USER_AUTH=
# user-service envía a org-service (para validar departamentoId/areaId/cargoId en PATCH /users/:id):
INTERNAL_TOKEN_USER_ORG=
# Tokens aceptados en endpoints /internal/* de user-service (uno por llamante):
INTERNAL_TOKEN_AUTH_USER=
INTERNAL_TOKEN_NOTIF_USER=
INTERNAL_TOKEN_WORKFLOW_USER=
INTERNAL_TOKEN_ORG_USER=

# URL interna del auth-service
# Local (directo):   http://localhost:3000
# Local (KinD):      http://auth-service.gestor-documental.svc.cluster.local
# Railway:           http://auth-service.railway.internal:3000
AUTH_SERVICE_URL=http://localhost:3000

# URL interna del org-service (para validar referencias de estructura organizacional)
ORG_SERVICE_URL=http://localhost:3002

HEALTH_PATH=/health

# JWT — misma clave que auth-service (solo para verificar firma)
JWT_SECRET=

# ─── Object Storage (avatares) ────────────────────────────────────────────────
# Bucket público — las URLs se sirven directamente al browser sin firma.
# Local (MinIO docker-compose):
#   STORAGE_ENDPOINT=http://localhost:9000
#   STORAGE_FORCE_PATH=true
#   STORAGE_PUBLIC_URL=http://localhost:9000/avatares
# Railway (R2 — mismo account que document-service, bucket separado con acceso público):
#   STORAGE_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
#   STORAGE_FORCE_PATH=false
#   STORAGE_PUBLIC_URL=https://pub-<hash>.r2.dev  (o dominio custom del bucket)
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_REGION=auto
STORAGE_ACCESS_KEY=minio_admin
STORAGE_SECRET_KEY=minio_secret_local
STORAGE_BUCKET=avatares
STORAGE_FORCE_PATH=true
STORAGE_PUBLIC_URL=http://localhost:9000/avatares

# Sentry error tracking (leave empty to disable)
SENTRY_DSN=
