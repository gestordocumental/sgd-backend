NODE_ENV=development
PORT=3003

# ─── MongoDB ──────────────────────────────────────────────────────────────────
# Local:    mongodb://mongo_admin:<password>@localhost:27017/document_db?authSource=admin
# KinD:     mongodb://document_user:<password>@mongodb.sgd-infra.svc.cluster.local:27017/document_db?authSource=admin
# Railway:  (cadena de conexión del plugin MongoDB de Railway)
MONGODB_URI=

# ─── Storage ──────────────────────────────────────────────────────────────────
# Local (MinIO):   STORAGE_ENDPOINT=http://localhost:9000  /  STORAGE_FORCE_PATH=true
# Railway (R2):    STORAGE_ENDPOINT=https://<account>.r2.cloudflarestorage.com  /  STORAGE_FORCE_PATH=false
STORAGE_ENDPOINT=
STORAGE_REGION=auto
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
STORAGE_BUCKET=documentos
STORAGE_FORCE_PATH=false
SIGNED_URL_EXPIRY=300

# ─── Kafka ────────────────────────────────────────────────────────────────────
# Local (host → docker-compose): localhost:9094
# KinD:     kafka.sgd-infra.svc.cluster.local:9092
# Railway:  kafka.railway.internal:9092
KAFKA_BROKER=
KAFKA_CLIENT_ID=document-service
KAFKA_CONSUMER_GROUP=document-service-group

# ─── org-service ──────────────────────────────────────────────────────────────
# Local:    http://localhost:3002
# KinD:     http://org-service.gestor-documental.svc.cluster.local
# Railway:  http://org-service.railway.internal:3000
ORG_SERVICE_URL=

# ─── Token interno entre microservicios ──────────────────────────────────────
INTERNAL_TOKEN=

# ─── metadata-extractor-service ───────────────────────────────────────────────
# Local:    http://localhost:3004
# KinD:     http://metadata-extractor-service.gestor-documental.svc.cluster.local
METADATA_EXTRACTOR_URL=

HEALTH_PATH=/health

# JWT — misma clave que auth-service (solo para verificar firma)
JWT_SECRET=
