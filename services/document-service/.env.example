# â”€â”€â”€ org-service â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
# Local:    http://localhost:3002
# KinD:     http://org-service.gestor-documental.svc.cluster.local
# Railway:  http://org-service.railway.internal:3000
ORG_SERVICE_URL=

# â”€â”€ Tokens internos de servicio a servicio â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
# Cada token identifica un par (origen â†’ destino).  Generar con:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# document-service envÃ­a a org-service:
INTERNAL_TOKEN_DOC_ORG=
# Tokens aceptados en endpoints /internal/* de document-service:
INTERNAL_TOKEN_WORKFLOW_DOC=

# â”€â”€â”€ metadata-extractor-service â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
