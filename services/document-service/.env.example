NODE_ENV=development
PORT=3003

# ─── MongoDB ──────────────────────────────────────────────────────────────────────────────────────────
# Local:    mongodb://mongo_admin:<password>@localhost:27017/document_db?authSource=admin
# KinD:     mongodb://document_user:<password>@mongodb.sgd-infra.svc.cluster.local:27017/document_db?authSource=admin
# Railway:  (cadena de conexión del plugin MongoDB de Railway)
MONGODB_URI=

# ─── Storage ──────────────────────────────────────────────────────────────────────────────────────────
# Local (MinIO):   STORAGE_ENDPOINT=http://localhost:9000  /  STORAGE_FORCE_PATH=true
# Railway (R2):    STORAGE_ENDPOINT=https://<account>.r2.cloudflarestorage.com  /  STORAGE_FORCE_PATH=false
STORAGE_ENDPOINT=
STORAGE_REGION=auto
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
STORAGE_BUCKET=documentos
STORAGE_FORCE_PATH=false
# Signed URL lifetime in seconds. Default 300 (5 min). Max 3600 in production (enforced at startup).
# Frontend should call /signed-url on-demand (on click), not pre-fetch; use the returned `expiresAt`
# to skip a re-fetch if a cached URL is still valid.
SIGNED_URL_EXPIRY=300

# ─── Kafka ────────────────────────────────────────────────────────────────────────────────────────────
# Local (host → docker-compose): localhost:9094
# KinD:     kafka.sgd-infra.svc.cluster.local:9092
# Railway:  kafka.railway.internal:9092
KAFKA_BROKER=
KAFKA_CLIENT_ID=document-service
KAFKA_CONSUMER_GROUP=document-service-group

# ─── org-service ──────────────────────────────────────────────────────────────────────────────────────
# Local:    http://localhost:3002
# KinD:     http://org-service.gestor-documental.svc.cluster.local
# Railway:  http://org-service.railway.internal:3000
ORG_SERVICE_URL=

# ── Tokens internos de servicio a servicio ────────────────────────────────────────────────────────────
# Cada token identifica un par (origen → destino).  Generar con:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# document-service envía a org-service:
INTERNAL_TOKEN_DOC_ORG=
# ⚠️  DEPRECADO — Este token actúa como bypass global de JWT en TODAS las rutas del servicio.
# Si se filtra, un atacante puede llamar cualquier endpoint sin autenticación.
# TODO: eliminar en favor de tokens por par (INTERNAL_TOKEN_<ORIGEN>_<DESTINO>) con InternalGuard
#       en endpoints /internal/* y reenvío de JWT de usuario en rutas normales.
# Mientras se migra, rotar este secreto ante cualquier sospecha de filtración.
INTERNAL_TOKEN=
# Tokens aceptados en endpoints /internal/* de document-service (vía InternalGuard):
INTERNAL_TOKEN_WORKFLOW_DOC=

# ── IP allowlisting — defensa en profundidad para endpoints /internal/* ───────
# CIDR(s) permitidos como origen de llamadas internas (separados por coma).
# Railway private network: 100.64.0.0/10
# Local dev / tests:       127.0.0.1,::1
# Dejar vacío para deshabilitar la comprobación (solo token).
INTERNAL_ALLOWED_CIDRS=

# ─── metadata-extractor-service ───────────────────────────────────────────────────────────────────────
# Local:    http://localhost:3004
# KinD:     http://metadata-extractor-service.gestor-documental.svc.cluster.local
METADATA_EXTRACTOR_URL=

# JWT — misma clave que auth-service (solo para verificar firma)
JWT_SECRET=
JWT_SECRET_KID=v1
JWT_SECRET_PREV=
JWT_SECRET_PREV_KID=

# ─── ClamAV malware scanning ──────────────────────────────────────────────────────────────────────────
# Local (docker-compose):  CLAMAV_HOST=localhost  CLAMAV_PORT=3310
# Railway:                 CLAMAV_HOST=clamav.railway.internal  CLAMAV_PORT=3310
# CLAMAV_REQUIRED=true  → upload is blocked if ClamAV is unreachable (fail-closed).
# CLAMAV_REQUIRED=false → upload proceeds with a warning if ClamAV is unreachable (fail-open).
CLAMAV_HOST=localhost
CLAMAV_PORT=3310
CLAMAV_TIMEOUT_MS=15000
CLAMAV_REQUIRED=false

# OpenTelemetry — distributed tracing
# Dejar vacío para deshabilitar (ej: en tests). Jaeger local: docker compose up jaeger
OTEL_EXPORTER_OTLP_ENDPOINT=

# Sentry error tracking (leave empty to disable)
SENTRY_DSN=
