NODE_ENV=development
PORT=3005

# PostgreSQL â€” base de datos dedicada workflow_db
DB_HOST=localhost
DB_PORT=5432
DB_POOL_SIZE=15
DB_NAME=workflow_db
DB_USERNAME=workflow_user
DB_PASSWORD=workflow_pass_local

# JWT â€” misma clave que auth-service (solo para verificar firma)
JWT_SECRET=
JWT_SECRET_KID=v1
JWT_SECRET_PREV=
JWT_SECRET_PREV_KID=

# â”€â”€ Tokens internos de servicio a servicio â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
# Cada token identifica un par (origen â†’ destino).  Generar con:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# workflow-service envÃ­a a user-service:
INTERNAL_TOKEN_WORKFLOW_USER=
# workflow-service envÃ­a a document-service:
INTERNAL_TOKEN_WORKFLOW_DOC=

# URLs internas de otros microservicios
# Local (directo):  http://localhost:<puerto>
# Railway:          http://<service>.railway.internal:3000
DOCUMENT_SERVICE_URL=http://localhost:3003
USER_SERVICE_URL=http://localhost:3001

# Timeouts para llamadas HTTP internas (ms)
DOCUMENT_SERVICE_TIMEOUT_MS=5000
USER_SERVICE_TIMEOUT_MS=5000

# Kafka
KAFKA_BROKER=localhost:9094
KAFKA_CLIENT_ID=workflow-service

# Sentry error tracking (leave empty to disable)
SENTRY_DSN=
