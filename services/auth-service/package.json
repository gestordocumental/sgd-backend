{
  "name": "auth-service",
  "version": "1.0.0",
  "scripts": {
    "build": "nest build",
    "start": "node dist/main",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:int": "jest --config jest.integration.config.js --runInBand",
    "typeorm": "ts-node ../../node_modules/typeorm/cli.js",
    "typeorm:prod": "node ../../node_modules/typeorm/cli.js",
    "migration:generate": "npm run typeorm -- migration:generate -d src/data-source.ts",
    "migration:run": "ts-node migrate.ts run",
    "migration:run:prod": "npm run typeorm:prod -- migration:run -d dist/data-source.js",
    "migration:revert": "ts-node migrate.ts revert",
    "migration:show": "ts-node migrate.ts show",
    "start:prod": "node dist/main",
    "start:migrate": "npm run migration:run:prod && npm run start:prod",
    "test:pact:consumer": "jest --config jest.pact.config.js --testPathPattern pact\\.spec",
    "test:pact:verify": "jest --config jest.pact.config.js --testPathPattern provider\\.spec"
  },
  "dependencies": {
    "@nestjs/axios": "^4.0.1",
    "@nestjs/common": "^11.1.21",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.1.21",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/platform-express": "^11.1.21",
    "@nestjs/swagger": "^11.4.3",
    "@nestjs/terminus": "^11.0.0",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/typeorm": "^11.0.0",
    "@sentry/node": "^10.53.1",
    "@sgd/common": "*",
    "axios": "^1.7.0",
    "bcryptjs": "^2.4.3",
    "multer": "^2.2.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "ioredis": "^5.10.0",
    "opossum": "^8.2.0",
    "pg": "^8.22.0",
    "prom-client": "^15.1.3",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.0",
    "swagger-ui-express": "^5.0.1",
    "typeorm": "^0.3.20",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.21",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.1.21",
    "@types/bcryptjs": "^2.4.6",
    "@types/opossum": "^8.0.0",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "@pact-foundation/pact": "^12.5.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.0"
  }
}
