NODE_ENV=development
PORT=3000

# PostgreSQL
DB_HOST=localhost
# Railway Starter ~25 conns → budget 80% = 20 → 20 / 5 PG services ≈ 4 each.
# Para Developer (50) usar 8; para Pro (100+) usar 15. Nunca superar floor(max_connections*0.8/services).
DB_POOL_SIZE=5
DB_PORT=5432
DB_NAME=auth_db
DB_USERNAME=auth_user
DB_PASSWORD=

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
# Requerido. Local: redis_local_pass. Producción: openssl rand -hex 32 (nunca vacío).
REDIS_PASSWORD=

# JWT — debe coincidir con Kong configmap (kong.yaml → jwt_secrets[0].secret)
# Generar con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=
JWT_SECRET_KID=v1
# Rotación de clave — ver jwt-key.service.ts para el procedimiento completo.
# Durante la rotación: set JWT_SECRET_PREV=<valor anterior>, JWT_SECRET_PREV_KID=<kid anterior>,
# JWT_SECRET=<nueva clave>, JWT_SECRET_KID=<nuevo kid, e.g. "v2">. Después de JWT_EXPIRATION,
# vaciar JWT_SECRET_PREV y JWT_SECRET_PREV_KID.
JWT_SECRET_PREV=
JWT_SECRET_PREV_KID=

JWT_REFRESH_SECRET=
JWT_REFRESH_SECRET_KID=v1
JWT_REFRESH_SECRET_PREV=
JWT_REFRESH_SECRET_PREV_KID=

JWT_EXPIRATION=3600s
JWT_REFRESH_EXPIRATION=7d

# Super admin — se crea automáticamente en cada arranque en frío si no existe.
# ⚠️  REQUERIDO: el servicio lanza error al iniciar si alguno está vacío.
#    Mínimo: 8 caracteres, mayúscula, número y símbolo (política de auth-service).
#    Generar con: openssl rand -base64 16
SUPER_ADMIN_EMAIL=admin@sgd.local
SUPER_ADMIN_PASSWORD=

# ── Tokens internos de servicio a servicio ────────────────────────────────────
# Cada token identifica un par (origen → destino).  Generar con:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# auth-service envía a user-service:
INTERNAL_TOKEN_AUTH_USER=
# user-service envía a auth-service (para validar llamadas entrantes):
INTERNAL_TOKEN_USER_AUTH=

# ── IP allowlisting — defensa en profundidad para endpoints /internal/* ───────
# CIDR(s) permitidos como origen de llamadas internas (separados por coma).
# Railway private network: 100.64.0.0/10
# Local dev / tests:       127.0.0.1,::1
# Dejar vacío para deshabilitar la comprobación (solo token).
INTERNAL_ALLOWED_CIDRS=

# URL interna del user-service (para consultar empresas del usuario)
USER_SERVICE_URL=http://user-service:3000

# bcrypt cost factor (default 12, min recommended 10). Higher = more secure but slower.
BCRYPT_ROUNDS=12

HEALTH_PATH=/health

# ── Rate limiting por IP (NestJS Throttler) ───────────────────────────────────
# TTL de la ventana en milisegundos (default: 60000 = 1 min).
# Límite de requests por IP en esa ventana (default: 10).
# Subir en entornos de test/staging para no bloquear pruebas de carga.
THROTTLE_LIMIT=10
THROTTLE_TTL=60000

# Kafka (producer only — eventos de reset de contraseña)
KAFKA_BROKER=
KAFKA_CLIENT_ID=auth-service

# OpenTelemetry — distributed tracing
# Dejar vacío para deshabilitar (ej: en tests). Jaeger local: docker compose up jaeger
OTEL_EXPORTER_OTLP_ENDPOINT=

# Sentry error tracking (leave empty to disable)
SENTRY_DSN=
