NODE_ENV=development
PORT=3000

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=auth_db
DB_USERNAME=auth_user
DB_PASSWORD=

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT — debe coincidir con Kong configmap (kong.yaml → jwt_secrets[0].secret)
JWT_SECRET=
JWT_REFRESH_SECRET=
JWT_EXPIRATION=3600s
JWT_REFRESH_EXPIRATION=7d

# Token interno para llamadas entre microservicios
INTERNAL_TOKEN=

# URL interna del user-service (para consultar empresas del usuario)
USER_SERVICE_URL=http://user-service.railway.internal:3000

# bcrypt cost factor (default 12, min recommended 10). Higher = more secure but slower.
BCRYPT_ROUNDS=12

HEALTH_PATH=/health

# Sentry error tracking (leave empty to disable)
SENTRY_DSN=
