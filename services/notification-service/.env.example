NODE_ENV=development
PORT=3006

# Redis — usado para almacenar tickets SSE efímeros (TTL 30s)
REDIS_HOST=localhost
REDIS_PORT=6379
# Requerido. Local: redis_local_pass. Producción: openssl rand -hex 32 (nunca vacío).
REDIS_PASSWORD=

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
# Railway Starter ~25 conns → budget 80% = 20 → 20 / 5 PG services ≈ 4 each.
# For Developer (50) use 8; for Pro (100+) use 15. Never exceed floor(max_connections*0.8/services).
DB_POOL_SIZE=5
DB_NAME=notification_db
DB_USERNAME=notification_user
DB_PASSWORD=

# JWT — misma clave que auth-service (solo para verificar firma)
JWT_SECRET=
JWT_SECRET_KID=v1
JWT_SECRET_PREV=
JWT_SECRET_PREV_KID=

# ── Tokens internos de servicio a servicio ────────────────────────────────────────────────────────────
# Cada token identifica un par (origen → destino).  Generar con:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# notification-service envía a user-service:
INTERNAL_TOKEN_NOTIF_USER=
# notification-service envía a org-service:
INTERNAL_TOKEN_NOTIF_ORG=

# URL interna del user-service (para obtener email de los destinatarios)
USER_SERVICE_URL=http://localhost:3001

# URL interna del org-service (para resolver nombre de la organización)
ORG_SERVICE_URL=http://localhost:3002

# URL del frontend — usada para construir el enlace de invitación
# Ejemplo: https://sgd-frontend.vercel.app
FRONTEND_URL=

# Resend — servicio de envío de correos (https://resend.com)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
RESEND_FROM="SGD Helisa <no-reply@helisa.com>"

# Kafka
KAFKA_BROKER=localhost:9094
KAFKA_CLIENT_ID=notification-service
KAFKA_CONSUMER_GROUP=notification-service-group

# Solo para desarrollo local con proxy SSL corporativo — NO agregar en Railway
# DISABLE_TLS_VERIFY=true

# OpenTelemetry — distributed tracing
# Dejar vacío para deshabilitar (ej: en tests). Jaeger local: docker compose up jaeger
OTEL_EXPORTER_OTLP_ENDPOINT=

# Sentry error tracking (leave empty to disable)
SENTRY_DSN=
