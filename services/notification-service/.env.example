NODE_ENV=development
PORT=3006

# Redis â€” usado para almacenar tickets SSE efÃ­meros (TTL 30s)
REDIS_HOST=localhost
REDIS_PORT=6379
# Requerido. Local: redis_local_pass. Producción: openssl rand -hex 32 (nunca vacío).
REDIS_PASSWORD=

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_POOL_SIZE=15
DB_NAME=notification_db
DB_USERNAME=notification_user
DB_PASSWORD=

# JWT â€” misma clave que auth-service (solo para verificar firma)
JWT_SECRET=
JWT_SECRET_KID=v1
JWT_SECRET_PREV=
JWT_SECRET_PREV_KID=

# â”€â”€ Tokens internos de servicio a servicio â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
# Cada token identifica un par (origen â†’ destino).  Generar con:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# notification-service envÃ­a a user-service:
INTERNAL_TOKEN_NOTIF_USER=
# notification-service envÃ­a a org-service:
INTERNAL_TOKEN_NOTIF_ORG=

# URL interna del user-service (para obtener email de los destinatarios)
USER_SERVICE_URL=http://localhost:3001

# URL interna del org-service (para resolver nombre de la organizaciÃ³n)
ORG_SERVICE_URL=http://localhost:3002

# URL del frontend â€” usada para construir el enlace de invitaciÃ³n
# Ejemplo: https://sgd-frontend.vercel.app
FRONTEND_URL=

# Resend â€” servicio de envÃ­o de correos (https://resend.com)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
RESEND_FROM="SGD Helisa <no-reply@helisa.com>"

# Kafka
KAFKA_BROKER=localhost:9094
KAFKA_CLIENT_ID=notification-service
KAFKA_CONSUMER_GROUP=notification-service-group

# Solo para desarrollo local con proxy SSL corporativo â€” NO agregar en Railway
# DISABLE_TLS_VERIFY=true

HEALTH_PATH=/health

# Sentry error tracking (leave empty to disable)
SENTRY_DSN=
