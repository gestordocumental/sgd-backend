NODE_ENV=development
PORT=3002

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_POOL_SIZE=15
DB_NAME=org_db
DB_USERNAME=postgres
DB_PASSWORD=

# â”€â”€ Tokens internos de servicio a servicio â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
# Cada token identifica un par (origen â†’ destino).  Generar con:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# org-service envÃ­a a user-service:
INTERNAL_TOKEN_ORG_USER=
# Tokens aceptados en endpoints /internal/* de org-service (uno por llamante):
INTERNAL_TOKEN_NOTIF_ORG=
INTERNAL_TOKEN_DOC_ORG=
INTERNAL_TOKEN_USER_ORG=

# URL base de user-service (sin trailing slash) â€” usada por OrgPermissionsGuard
USER_SERVICE_URL=http://user-service:3001

HEALTH_PATH=/health

# JWT â€” misma clave que auth-service (solo para verificar firma)
JWT_SECRET=
JWT_SECRET_KID=v1
JWT_SECRET_PREV=
JWT_SECRET_PREV_KID=

# Kafka â€” para emitir eventos de auditorÃ­a
KAFKA_BROKER=kafka:9092
KAFKA_CLIENT_ID=org-service

# Sentry error tracking (leave empty to disable)
SENTRY_DSN=
