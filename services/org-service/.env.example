NODE_ENV=development
PORT=3002

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=org_db
DB_USERNAME=postgres
DB_PASSWORD=

# Token interno para llamadas entre microservicios
INTERNAL_TOKEN=change-me-in-production

# URL base de user-service (sin trailing slash) — usada por OrgPermissionsGuard
USER_SERVICE_URL=http://user-service:3001

HEALTH_PATH=/health
