NODE_ENV=development
PORT=3002

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_POOL_SIZE=15
DB_NAME=org_db
DB_USERNAME=postgres
DB_PASSWORD=

# ── Tokens internos de servicio a servicio ────────────────────────────────────────────────────────────
# Cada token identifica un par (origen → destino).  Generar con:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# org-service envía a user-service:
INTERNAL_TOKEN_ORG_USER=
# Tokens aceptados en endpoints /internal/* de org-service (uno por llamante):
INTERNAL_TOKEN_NOTIF_ORG=
INTERNAL_TOKEN_DOC_ORG=
INTERNAL_TOKEN_USER_ORG=

# ── IP allowlisting — defensa en profundidad para endpoints /internal/* ───────
# CIDR(s) permitidos como origen de llamadas internas (separados por coma).
# Railway private network: 100.64.0.0/10
# Local dev / tests:       127.0.0.1,::1
# Dejar vacío para deshabilitar la comprobación (solo token).
INTERNAL_ALLOWED_CIDRS=

# URL base de user-service (sin trailing slash) — usada por OrgPermissionsGuard
USER_SERVICE_URL=http://user-service:3001

HEALTH_PATH=/health

# JWT — misma clave que auth-service (solo para verificar firma)
JWT_SECRET=
JWT_SECRET_KID=v1
JWT_SECRET_PREV=
JWT_SECRET_PREV_KID=

# Kafka — para emitir eventos de auditoría
KAFKA_BROKER=kafka:9092
KAFKA_CLIENT_ID=org-service

# Sentry error tracking (leave empty to disable)
SENTRY_DSN=
