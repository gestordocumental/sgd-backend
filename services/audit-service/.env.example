NODE_ENV=development
PORT=3007

# JWT — misma clave que auth-service (solo para verificar firma)
JWT_SECRET=
JWT_SECRET_KID=v1
JWT_SECRET_PREV=
JWT_SECRET_PREV_KID=

# Token interno para llamadas entre microservicios
INTERNAL_TOKEN=

# Elasticsearch
# Local: usuario elastic con ELASTIC_PASSWORD del docker-compose.
# Produccion: crear usuarios dedicados con minimos privilegios:
#   WRITE — indices:data/write/index + indices:admin/create  (Kafka consumer)
#   READ  — indices:data/read                                (HTTP audit queries)
#
# IMPORTANTE: main.ts exige ELASTICSEARCH_USERNAME y ELASTICSEARCH_PASSWORD
# (genéricos) cuando NODE_ENV=production. En Railway debes configurar ambos
# conjuntos: los genéricos (para satisfacer el guard) y los por rol (para
# que el módulo use credenciales separadas). Si solo configuras los de rol,
# el servicio crashea al arrancar en producción.
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_USERNAME=elastic
ELASTICSEARCH_PASSWORD=
ELASTICSEARCH_WRITE_USERNAME=elastic
ELASTICSEARCH_WRITE_PASSWORD=
ELASTICSEARCH_READ_USERNAME=elastic
ELASTICSEARCH_READ_PASSWORD=

# Kafka
KAFKA_BROKER=localhost:9094
KAFKA_CLIENT_ID=audit-service
KAFKA_CONSUMER_GROUP=audit-service-group

# OpenTelemetry — distributed tracing
# Dejar vacío para deshabilitar (ej: en tests). Jaeger local: docker compose up jaeger
OTEL_EXPORTER_OTLP_ENDPOINT=

# Solo para desarrollo local con proxy SSL corporativo — NO agregar en Railway
# DISABLE_TLS_VERIFY=true

# Sentry error tracking (leave empty to disable)
SENTRY_DSN=
