{
  "name": "@sgd/common",
  "version": "1.0.0",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./correlation/correlation.context": {
      "types": "./dist/correlation/correlation.context.d.ts",
      "default": "./dist/correlation/correlation.context.js"
    },
    "./metrics/metrics.registry": {
      "types": "./dist/metrics/metrics.registry.d.ts",
      "default": "./dist/metrics/metrics.registry.js"
    }
  },
  "dependencies": {
    "@opentelemetry/sdk-node": "^0.218.0",
    "@opentelemetry/auto-instrumentations-node": "^0.76.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.218.0",
    "@opentelemetry/resources": "^1.30.0",
    "@opentelemetry/semantic-conventions": "^1.30.0",
    "@nestjs/common": "^11.1.21",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.1.21",
    "@nestjs/swagger": "^11.4.3",
    "@sentry/node": "^10.53.1",
    "jsonwebtoken": "^9.0.3",
    "kafkajs": "^2.2.4",
    "prom-client": "^15.1.3",
    "rxjs": "^7.8.0",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.0.0"
  }
}
