# Variables del API Gateway (Kong) — copiar a .env antes de levantar localmente.
#   cp .env.example .env
#
# NOTA: Las variables *_SERVICE_URL de cada microservicio están documentadas
# en services/<servicio>/.env.example, no aquí.

# ── JWT ───────────────────────────────────────────────────────────────────────
# Debe coincidir con JWT_SECRET de auth-service.
KONG_JWT_SECRET=change-me-in-production

# ── Kong general ──────────────────────────────────────────────────────────────
# "off" = modo declarativo (DB-less). No cambiar.
KONG_DATABASE=off
# Buffer nginx para uploads de documentos grandes (ej: 10m).
KONG_NGINX_PROXY_CLIENT_BODY_BUFFER_SIZE=10m

# ── CORS ──────────────────────────────────────────────────────────────────────
# URL del frontend (sin trailing slash). En Railway usar la URL pública del frontend.
# En local usar http://localhost:<puerto-del-frontend>.
FRONTEND_URL=http://localhost:3010

# ── Rate limiting (solicitudes/minuto por token JWT) ─────────────────────────
# En producción usar valores bajos para sensibles (login, reset-password).
# En staging/dev/test se puede subir para no bloquear pruebas de carga.
USER_RATE_LIMIT=300
AUTH_SENSITIVE_RATE_LIMIT=10
AUTH_SESSION_RATE_LIMIT=2000
